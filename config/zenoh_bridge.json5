{
  // CRUCIBLE Zenoh ROS2 DDS Bridge Configuration
  //
  // This bridge runs alongside the sim engine and routes simulated
  // sensor topics to agent stacks via Zenoh. Agent stacks peer with
  // this bridge the same way they peer with each other in reality.

  mode: "router",

  listen: {
    endpoints: [
      "tcp/0.0.0.0:7447"
    ]
  },

  // Scouting for peer discovery on the Docker network
  scouting: {
    multicast: {
      enabled: true
    }
  },

  // ROS2 DDS plugin configuration
  plugins: {
    ros2dds: {
      // Bridge the sim engine's DDS domain
      domain: 0,

      // Allow all agent-namespaced topics through
      // Each agent's topics follow the pattern: /<agent_name>/<sensor_suffix>
      //
      // publishers:  topics for which sim_engine has a local DDS publisher
      //              that the bridge announces on zenoh (sim → agents).
      // subscribers: topics for which sim_engine has a local DDS subscriber
      //              the bridge fulfills from zenoh (agents → sim).
      //
      // gps/fix and imu/data appear in BOTH lists: sim publishes synthesized
      // sensor data for normal agents, and subscribes to those same topics
      // when an agent uses the log_playback motion model and a bag in the
      // agent stack drives its pose.
      allow: {
        publishers: [
          "*/gps/fix",
          "*/imu/data",
          "*/altimeter/data",
          "*/twr/ranges",
          "*/sim/ground_truth",
          "/clock"
        ],
        subscribers: [
          "*/cmd_vel",
          "*/pose/estimate",
          "*/gps/fix",
          "*/imu/data"
        ],
        services: [
          "/sim/**"
        ]
      }
    }
  }
}
